# ROS2 Sunshine Docker Configuration

# Display configuration (if X11 forwarding is available)
# Use :0 for local display or set to remote display if needed
DISPLAY=:0

# ROS2 Configuration
ROS_DISTRO=jazzy
ROS_DOMAIN_ID=0

# Sunshine Configuration
# IMPORTANT: Change these credentials!
SUNSHINE_USERNAME=admin
SUNSHINE_PASSWORD=change_me

# GPU Configuration (GTX 1080 Ti)
# Can be set to specific GPU index or 'all' for all GPUs
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=graphics,compute,utility

# Video Stream Configuration
SUNSHINE_BITRATE=20000  # kbps (20 Mbps)
SUNSHINE_FRAMERATE=60   # fps
SUNSHINE_QUALITY=high   # low, medium, high
SUNSHINE_RESOLUTION_WIDTH=1920
SUNSHINE_RESOLUTION_HEIGHT=1080

# Timezone (optional)
TZ=UTC
